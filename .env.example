# Optional API-key authentication for the agent.
#
# This file is the shared template and is tracked by git. To use an API key
# instead of your Claude Code login, copy it to `.env` (gitignored) and set your
# real key there:
#
#     cp .env.example .env
#
# The agent only loads `.env`, so with no `.env` present it keeps using your
# Claude Code login. An already-set ANTHROPIC_API_KEY env var is never
# overridden. Never commit a real key; rotate any key that leaks.

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY
